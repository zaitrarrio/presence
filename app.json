{
  "expo": {
    "name": "Presence",
    "slug": "presence",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "presence",
    "userInterfaceStyle": "automatic",
    "backgroundColor": "#EEEBF5",
    "ios": {
      "supportsTablet": true,
      "icon": "./assets/expo.icon",
      "infoPlist": {
        "NSCameraUsageDescription": "Presence uses your front camera so your companion can see you during a live conversation.",
        "NSMicrophoneUsageDescription": "Presence uses your microphone so your companion can hear you during a live conversation."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#EEEBF5",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "permissions": ["android.permission.CAMERA", "android.permission.RECORD_AUDIO"],
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Presence uses your front camera so your companion can see you during a live conversation.",
          "microphonePermission": "Presence uses your microphone so your companion can hear you during a live conversation.",
          "recordAudioAndroid": true
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#EEEBF5",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 92
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
