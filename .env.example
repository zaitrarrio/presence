# Copy to `.env` to run Presence against the real Vidu S1 API.
# With no key set, the app runs in Preview mode against the built-in mock.

# Your Vidu S1 API key (https://platform.vidu.com/). Enables live mode.
EXPO_PUBLIC_VIDU_API_KEY=

# Optional: override the Vidu API base URL.
# EXPO_PUBLIC_VIDU_BASE_URL=https://api.vidu.com
